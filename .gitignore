# =========================
# Ambiente virtual
# =========================
.venv/

# =========================
# .bin ? ignorar tudo por defeito
# =========================
.bin/*

# Permitir apenas código e configs dentro da .bin
!.bin/**/*.py
!.bin/**/*.spec
!.bin/**/*.json
!.bin/**/*.txt

# =========================
# Python cache
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# Build / distribuiçăo
# =========================
build/
dist/

# =========================
# Executáveis
# =========================
*.exe
!faturas_facilities_*.exe

