# =========================
# Ambiente virtual
# =========================
.venv/
.bin/.venv/

# =========================
# Python cache
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd

# =========================
# Build / distribuição
# =========================
build/
dist/
.bin/build/
.bin/dist/

# =========================
# Ficheiros do PyInstaller
# =========================
*.spec

# =========================
# Executáveis
# Ignorar todos por defeito, mas permitir o final desta app
# =========================
*.exe
!Invoice_AutoHandler_*.exe

# =========================
# Base de dados / runtime / temporários
# =========================
*.db
*.xml
draft_*.txt

# =========================
# PDFs e Excel operacionais
# =========================
*.pdf
*.xlsx
*.xls

# =========================
# Exceções que DEVEM ficar no repositório
# =========================
!splash_saas.png
!.bin/**/*.py
!.bin/**/*.json
!.bin/**/*.txt
!.bin/**/*.csv

# =========================
# IMPORTANTE:
# garantir que Excel dentro da .bin continua ignorado
# mesmo com exceções acima
# =========================
.bin/**/*.xlsx
.bin/**/*.xls
.bin/**/*.pdf
.bin/**/*.db

# =========================
# Logs / backups
# =========================
logs/
backup/
.bin/logs/
.bin/backup/

# =========================
# VS Code
# =========================
.vscode/

# =========================
# Windows
# =========================
Thumbs.db
Desktop.ini

